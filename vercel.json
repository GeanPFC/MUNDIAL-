{
  "version": 2,
  "installCommand": "echo no install",
  "buildCommand": "echo no build",
  "crons": [
    {
      "path": "/api/refresh",
      "schedule": "0 8 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
